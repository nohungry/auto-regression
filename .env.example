# =============================================
# 多站點設定範本 - 複製此檔案為 .env 並填入實際值
# =============================================

# 預設執行站點（執行 pytest 時若未指定 --site 則用此值）
DEFAULT_SITE=wlj

# -----------------------------------------------
# 執行環境說明
# -----------------------------------------------
# Windows：Playwright 直接啟動 Chrome，不需要任何手動操作
# WSL：自動啟動 Windows Chrome（需設定正確的 CDP_URL）
#   CDP_URL 填 Windows host IP（通常為 172.x.x.x），可用 `cat /etc/resolv.conf` 查詢
# 純 Linux：需手動啟動 Chrome 並設定 CDP_URL

# 是否無頭模式（Windows 適用，預設 false 會顯示瀏覽器視窗）
HEADLESS=false

# CDP 連線位址（WSL / 純 Linux 環境需要設定，Windows 不需要）
# WSL 範例：CDP_URL=http://172.29.96.1:9222
CDP_URL=http://127.0.0.1:9222

# -----------------------------------------------
# 王老吉站點 (wlj)
# -----------------------------------------------
SITE_WLJ_URL=https://dev-drc.t9platform-ph.com/
SITE_WLJ_USERNAME=your_username
SITE_WLJ_PASSWORD=your_password

# -----------------------------------------------
# 其他站點範例 (xxx) - 複製此區塊新增站點
# -----------------------------------------------
# SITE_XXX_URL=https://xxx.example.com/
# SITE_XXX_USERNAME=your_username
# SITE_XXX_PASSWORD=your_password
