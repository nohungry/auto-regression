# =============================================
# 多站點設定範本 - 複製此檔案為 .env 並填入實際值
# =============================================

# 預設執行站點（執行 pytest 時若未指定 --site 則用此值）
DEFAULT_SITE=drc

# -----------------------------------------------
# 執行環境說明
# -----------------------------------------------
# Windows：Playwright 直接啟動 Chrome，不需要任何手動操作
# WSL：自動啟動 Windows Chrome（需設定正確的 CDP_URL）
#   CDP_URL 填 Windows host IP（通常為 172.x.x.x），可用 `cat /etc/resolv.conf` 查詢
# 純 Linux：需手動啟動 Chrome 並設定 CDP_URL

# 是否無頭模式（Windows 適用，預設 false 會顯示瀏覽器視窗）
HEADLESS=false

# CDP 連線位址（WSL / 純 Linux 環境需要設定，Windows 不需要）
# WSL 範例：CDP_URL=http://<WINDOWS_HOST_IP>:9223
CDP_URL=http://<WINDOWS_HOST_IP>:9223

# -----------------------------------------------
# 站點一 (drc)
# -----------------------------------------------
SITE_DRC_URL=https://your-site-url.com/
SITE_DRC_USERNAME=your_username
SITE_DRC_PASSWORD=your_password
# SITE_DRC_API_URL=https://dev-web-api.t9platform.com
# SITE_DRC_API_DOMAIN=dev-drc.t9platform-ph.com

# -----------------------------------------------
# DLT來財站點 (dlt)
# -----------------------------------------------
# SITE_DLT_URL=https://dev-lt.t9platform.com/
# SITE_DLT_USERNAME=your_username
# SITE_DLT_PASSWORD=your_password
# SITE_DLT_API_URL=https://dev-web-api.t9platform.com
# SITE_DLT_API_DOMAIN=dev-lt.t9platform-ph.com

# -----------------------------------------------
# 其他站點範例 (xxx) - 複製此區塊新增站點
# -----------------------------------------------
# SITE_XXX_URL=https://xxx.example.com/
# SITE_XXX_USERNAME=your_username
# SITE_XXX_PASSWORD=your_password
