# 敏感資料 - 絕對不能進 git
.env

# Playwright
test-results/
playwright-report/

# Python
__pycache__/
*.pyc
.pytest_cache/

# Reports
reports/*.html
reports/*.xml

# Screenshots (test run artifacts)
screenshots/

# VS Code (machine-specific settings)
.vscode/

# MCP config (contains machine-specific Windows host IP)
.mcp.json

# Playwright MCP runtime logs
.playwright-mcp/

# Dev notes (personal scratch area, not shipped)
dev-notes/*
!dev-notes/README.md

# Claude Code
.claude/

# Python virtual environment
.venv/
